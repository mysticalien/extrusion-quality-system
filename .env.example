# Logging
LOG_LEVEL=info

# Backend
BACKEND_CONTAINER_NAME=extrusion_backend
BACKEND_PORT=8080

SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_READ_HEADER_TIMEOUT=3s

# PostgreSQL
POSTGRES_CONTAINER_NAME=extrusion_postgres
POSTGRES_DB=extrusion_quality
POSTGRES_USER=extrusion_user
POSTGRES_PASSWORD=<set-local-postgres-password>
DATABASE_URL=postgres://<user>:<password>@localhost:<port>/<database>?sslmode=disablePOSTGRES_PORT=55432

# MQTT
MQTT_ENABLED=true
MQTT_CONTAINER_NAME=extrusion_mqtt
MQTT_PORT=1883
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=extrusion-backend
MQTT_TELEMETRY_TOPIC=extrusion/telemetry/readings
MQTT_CONNECT_TIMEOUT=10s
MQTT_QOS=0
MQTT_WORKER_COUNT=4
MQTT_QUEUE_SIZE=256

# Kafka
KAFKA_ENABLED=true
KAFKA_CONTAINER_NAME=extrusion_kafka
KAFKA_HOST_PORT=19092
KAFKA_NODE_ID=1

KAFKA_BROKERS=localhost:19092
KAFKA_TELEMETRY_TOPIC=extrusion.telemetry.raw
KAFKA_CONSUMER_GROUP=extrusion-quality-service
KAFKA_WRITE_TIMEOUT=10s
KAFKA_READ_TIMEOUT=10s
KAFKA_RETRY_DELAY=2s

KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Simulator
SIMULATOR_CONTAINER_NAME=extrusion_telemetry_simulator
SIMULATOR_INTERVAL=2s
SIMULATOR_REQUEST_TIMEOUT=10s
SIMULATOR_SOURCE_ID=mqtt-simulator

SIMULATOR_MQTT_BROKER_URL=tcp://localhost:1883
SIMULATOR_MQTT_CLIENT_ID=extrusion-simulator
SIMULATOR_MQTT_TOPIC=extrusion/telemetry/readings
SIMULATOR_MQTT_QOS=0
SIMULATOR_MQTT_TIMEOUT=10s

# Auth / JWT
JWT_SECRET=local-development-secret-change-me-32-chars-min
JWT_TOKEN_TTL=24h
AUTH_TOKEN_ISSUER=extrusion-quality-system
AUTH_BCRYPT_COST=10